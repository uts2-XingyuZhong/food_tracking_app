!<!DOCTYPE html>
<html lang="en">
 <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pantry Pal</title>
    <link rel="stylesheet" href="/styles.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Nunito:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app-frame">
      <%- include("header.ejs")%>

      <main class="content">
        <section class="recipes-list">
  <% if (!savedRecipes || savedRecipes.length === 0) { %>
    <p class="recipes-empty">No recipes saved.</p>
  <% } else { %>
    <% savedRecipes.forEach(function (recipe) { %>
      <article class="recipe-card">
        <div class="recipe-thumb-wrap">
          <% if (recipe.image) { %>
            <img src="<%= recipe.image %>" alt="<%= recipe.title %>" class="recipe-thumb" />
          <% } else { %>
            <div class="recipe-thumb placeholder"></div>
          <% } %>
        </div>
        <div class="recipe-main">
          <h2 class="recipe-title"><%= recipe.title %></h2>
        </div>
      </article>
    <% }); %>
  <% } %>
</section>
      </main>

      <%- include("bottom_icons.ejs")%>
    </div>
</body>
</html>
