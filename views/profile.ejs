<!DOCTYPE html>
<html lang="en">
 <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pantry Pal</title>
    <link rel="stylesheet" href="/styles.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Nunito:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
  </head>
<body>
    <div class="app-frame">
      <%- include("header.ejs")%>
      <main class="content">
        <!-- Account Section -->
        <section class="profile-section">
          <h2 class="profile-section-title">Account</h2>
          
          <div class="account-info">
            <div class="account-field">
              <label class="account-label">NAME</label>
              <p class="account-value">Whitney Worker</p>
            </div>
            
            <div class="account-field">
              <label class="account-label">ACCOUNT ID</label>
              <p class="account-value">sjdgfs312</p>
            </div>
            
            <button class="change-password-btn">Change Password</button>
          </div>
        </section>

        <!-- Menu Items -->
        <section class="profile-menu">
          <div class="profile-menu-item">
            <span class="menu-text">NOTIFICATION SETTINGS</span>
          </div>
          
          <div class="profile-menu-item">
            <span class="menu-text">PAST RECIPES</span>
          </div>

          <div class="profile-menu-item">
            <span class="menu-text">PAST INGREDIENTS</span>
          </div>
          
          <div class="profile-menu-item">
            <span class="menu-text">SET PREFERENCES</span>
          </div>
        </section>

        <!-- Logout Button -->
        <div class="logout-container">
          <button class="logout-btn">Logout</button>
        </div>
      </main>
      <%- include("bottom_icons.ejs")%>
    </div>
             
</body>
</html>