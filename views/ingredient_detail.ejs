<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= ingredient.name %> - Pantry Pal</title>
    <link rel="stylesheet" href="/styles.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Nunito:wght@300;400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="app-frame">
      <%- include("header.ejs") %>

      <main class="content ingredient-detail-content">
        <nav class="breadcrumbs">
          <a href="/">Home</a>
          <span class="breadcrumb-sep">&gt;</span>
          <a href="/">Storage</a>
          <span class="breadcrumb-sep">&gt;</span>
          <span class="breadcrumb-current"><%= ingredient.name %></span>
        </nav>

        <section class="ingredient-overview">
          <div class="ingredient-overview-icon"><%= ingredient.icon %></div>
          <h1 class="ingredient-detail-name"><%= ingredient.name %></h1>
          <button class="icon-button edit-icon" aria-label="edit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16">
              <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/>
            </svg>
          </button>
        </section>

        <dl class="ingredient-details">
          <div class="detail-row">
            <dt class="detail-label">INGREDIENT NAME</dt>
            <dd class="detail-value"><%= ingredient.name %></dd>
          </div>
          <div class="detail-row">
            <dt class="detail-label">QTY.</dt>
            <dd class="detail-value"><%= ingredient.quantity ? (ingredient.quantity.toString().match(/^\d+$/) ? ingredient.quantity + ' Pcs.' : ingredient.quantity) : '-' %></dd>
          </div>
          <div class="detail-row">
            <dt class="detail-label">DATE ADDED</dt>
            <dd class="detail-value"><%= ingredient.dateAdded %></dd>
          </div>
          <div class="detail-row">
            <dt class="detail-label">BEST BEFORE</dt>
            <dd class="detail-value"><%= ingredient.bestBefore %></dd>
          </div>
        </dl>

        <div class="suggest-recipes-wrap">
          <form action="/ingredient/<%= ingredient.id %>/recipes" method="post">
            <button class="suggest-recipes-btn" type="submit">
              Suggest Recipes
            </button>
          </form>
        </div>
      </main>

      <%- include("bottom_icons.ejs") %>
    </div>
  </body>
</html>
